<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#909090">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingVertical="16dp"
        android:paddingHorizontal="20dp"
        android:baselineAligned="false">

        <!-- Links: Display -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="8dp"
            >

            <TextView
                android:id="@+id/display"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/rounded_corners"
                android:elevation="4dp"
                android:gravity="bottom|end"
                android:padding="24dp"
                android:text="0"
                android:textColor="@color/material_dynamic_primary10"
                android:textSize="80sp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Rechts: Keyboard -->
        <GridLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:rowCount="7"
            android:columnCount="4"
            >

            <!-- NEUE Reihe 0 -->
            <Button
                android:id="@+id/btn_sin"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="Sin"
                android:textSize="20sp"/>

            <Button
                android:id="@+id/btn_cos"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="Cos"
                android:textSize="20sp"/>


            <Button
                android:id="@+id/btn_tan"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="Tan"
                android:textSize="20sp"/>

            <Button
                android:id="@+id/btn_sqrt"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="Sqrt"
                android:textSize="20sp"/>

            <!-- Reihe 0 -->
            <Button
                android:id="@+id/btn_clear"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="C"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_clear_entry"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="CE"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_mem_read"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="MR"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_mem_save"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="MS"
                android:textSize="20sp" />

            <!-- Reihe 1 -->
            <Button
                android:id="@+id/btn_seven"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="7"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_eight"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="8"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_nine"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="9"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_div"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="/"
                android:textSize="24sp" />

            <!-- Reihe 2 -->
            <Button
                android:id="@+id/btn_four"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="4"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_five"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="5"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_six"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="6"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_mult"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="*"
                android:textSize="24sp" />

            <!-- Reihe 3 -->
            <Button
                android:id="@+id/btn_one"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="1"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_two"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="2"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_three"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="3"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_subtract"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="-"
                android:textSize="24sp" />

            <!-- Reihe 4 -->
            <Button
                android:id="@+id/btn_sign_change"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="+/-"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_zero"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="0"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_decimal"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="."
                android:textSize="24sp" />

            <Button
                android:id="@+id/btn_add"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="+"
                android:textSize="24sp" />

            <!-- Reihe 5: Equals & Parentheses -->
            <Button
                android:id="@+id/btn_equals"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_row="6"
                android:layout_column="0"
                android:layout_columnSpan="3"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="="
                android:textSize="28sp" />

            <Button
                android:id="@+id/btn_parentheses"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_row="6"
                android:layout_column="3"
                android:layout_columnSpan="1"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="( )"
                android:textSize="24sp" />

        </GridLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/copy_popup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/rounded_corners"
        android:backgroundTint="#CC000000"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_copy"
            android:contentDescription="Copy Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Kopiert"
            android:textColor="@android:color/white"
            android:textSize="18sp" />
    </LinearLayout>

</FrameLayout>